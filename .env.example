# Core
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://identity:identity@postgres:5432/identity
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=identity-results
MINIO_SECURE=false
DEV_AUTH_USER=dev-user
JOB_MAX_RETRIES=3

# Foocus adapter (photo worker)
# Options: mock | http | cli
FOOCUS_ADAPTER_MODE=mock
FOOCUS_HTTP_URL=http://host.docker.internal:8888/generate
FOOCUS_CLI_COMMAND=python /opt/foocus_new/entrypoint.py

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
